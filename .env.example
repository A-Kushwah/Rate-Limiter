# --- Server ---
PORT=3000
NODE_ENV=production

# --- Redis ---
# In Docker, use the service name. Locally or on Render, use the external URL.
REDIS_URL=redis://redis:6379

# --- Limiter defaults ---
# Algorithm: fixed-window | sliding-log | sliding-window | token-bucket | leaky-bucket
ALGORITHM=token-bucket
# Window / capacity / refill tuned for the demo. Override per-route in ROUTES_JSON.
WINDOW_MS=60000
LIMIT=60
BURST=20
# Key strategy: apiKey | userId | ip | composite
KEY_STRATEGY=ip

# --- Per-route overrides (JSON) ---
# Limit overrides for specific paths. Keys are matched as prefixes.
# Format: { "/login": { "limit": 5, "windowMs": 60000, "burst": 0, "algorithm": "fixed-window" } }
ROUTES_JSON={}

# --- Dashboard ---
DASHBOARD_ENABLED=true
